AZURE_FOUNDRY_ENDPOINT=https://<your-foundry-endpoint>
AZURE_FOUNDRY_API_KEY=<your-api-key>
AZURE_FOUNDRY_DEPLOYMENTS=DeepSeek-V3.2,gpt-5-mini,Mistral-Large-3
DEPLOYMENT_NAME=

# Arena Engine feature flags (Week 1)
FEATURE_ARENA_ELIMINATION=false
FEATURE_ARENA_METRICS_PANEL=false
FEATURE_ARENA_COST_DISPLAY=false

# Output Inspector feature flags (Week 2)
FEATURE_INSPECTOR_ENABLED=false
FEATURE_INSPECTOR_VALIDATE_JSON=false
FEATURE_INSPECTOR_VALIDATE_MARKDOWN=false
FEATURE_INSPECTOR_VALIDATE_XML=false
FEATURE_INSPECTOR_REQUIRED_FIELDS=false
FEATURE_INSPECTOR_NO_EXTRA_TEXT=false
FEATURE_INSPECTOR_TONE_CHECK=false
FEATURE_INSPECTOR_PERSONA_CHECK=false
FEATURE_INSPECTOR_HIGHLIGHTING=false

# Persistence & Memory feature flags (Week 3)
FEATURE_PERSISTENCE_COSMOS=false
FEATURE_ARENA_LEADERBOARD=false
FEATURE_PROMPT_MEMORY_ENABLED=false
FEATURE_KEYVAULT_ENABLED=false

# Cosmos DB configuration (required when FEATURE_PERSISTENCE_COSMOS=true)
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_ACCOUNT_KEY=
# Optional — if set, key-based auth is used; if empty, DefaultAzureCredential (RBAC) is used
COSMOS_DATABASE_NAME=llm_arena
COSMOS_CONTAINER_NAME=arena_results

# Privacy control — set true to store full prompt text in Cosmos (default: false)
PERSIST_PROMPT_TEXT=false

# Key Vault configuration (required when FEATURE_KEYVAULT_ENABLED=true)
KEYVAULT_URL=https://<your-vault-name>.vault.azure.net/
